APP_NAME=COOP Saving API
ENVIRONMENT=development
SECRET_KEY=change-this-secret-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Local default. For PostgreSQL use:
# DATABASE_URL=postgresql+psycopg2://coop:coop_password@localhost:5432/coop_saving
DATABASE_URL=sqlite:///./coop.db

CORS_ORIGINS=http://localhost:3000
AUTO_CREATE_TABLES=true
UPLOAD_DIR=uploads
PUBLIC_UPLOAD_BASE_URL=http://localhost:8000/uploads
MONTHLY_SAVING_AMOUNT=1000

ADMIN_EMAIL=admin@coop.local
ADMIN_PASSWORD=admin12345

GOOGLE_ENABLED=false
GOOGLE_SHEET_ID=
GOOGLE_SERVICE_ACCOUNT_FILE=
GOOGLE_SERVICE_ACCOUNT_JSON=
GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_DRIVE_PUBLIC_LINKS=false
